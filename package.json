{
  "name": "@zone-eu/types",
  "version": "0.1.3",
  "description": "Shared TypeScript types for the Zone.eu ZMS stack.",
  "license": "EUPL-1.1+",
  "type": "module",
  "sideEffects": false,
  "private": false,
  "keywords": [
    "wildduck",
    "zonemta",
    "zone-mta",
    "plugins",
    "plugin",
    "zms",
    "email",
    "zms types",
    "types"
  ],
  "homepage": "https://github.com/zone-eu/zms-types#readme",
  "bugs": {
    "url": "https://github.com/zone-eu/zms-types/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zone-eu/zms-types.git"
  },
  "files": [
    "dist"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "npm run build && npm run lint",
    "update": "rm -rf node_modules package-lock.json && ncu -u && npm install"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.1",
    "eslint": "10.4.0",
    "eslint-config-nodemailer": "1.2.0",
    "eslint-config-prettier": "10.1.8",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.4"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@zone-eu/mailsplit": "5.4.11"
  }
}
